VITE_BASE=/static/admin-spa/

# 是否开启压缩 none | brotli | gzip
VITE_COMPRESS=gzip

# vue-router 模式：hash 便于 /admin 单入口挂载
VITE_ROUTER_HISTORY=hash

# 是否注入全局loading
VITE_INJECT_APP_LOADING=true

# 不打包 dist.zip
VITE_ARCHIVER=false

# 后端接口（同域）
VITE_GLOB_API_URL=/admin/api

VITE_GLOB_ENABLE_ENCRYPT=false
VITE_GLOB_RSA_PUBLIC_KEY=
VITE_GLOB_RSA_PRIVATE_KEY=
VITE_GLOB_APP_CLIENT_ID=g2a-admin
VITE_GLOB_SSE_ENABLE=false
VITE_GLOB_WEBSOCKET_ENABLE=false

VITE_APP_BASE_API=/admin/api
