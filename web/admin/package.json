{
  "name": "grokcli-2api-admin",
  "version": "2.1.0",
  "description": "grokcli-2api admin SPA (Vue3 + antdv-next)",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "bootstrap": "pnpm install",
    "dev": "vite --mode development",
    "build": "vite build --mode production",
    "build:test": "vite build --mode test",
    "build:analyze": "vite build --mode analyze",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit --skipLibCheck",
    "check:cspell": "cspell lint \"**/*.ts\" \"**/README.md\" \".changeset/*.md\" --no-progress",
    "clean": "node ./scripts/clean.mjs",
    "format": "node ./scripts/lint.mjs --format",
    "lint": "node ./scripts/lint.mjs",
    "preinstall": "npx only-allow pnpm",
    "reinstall": "pnpm run clean -- --del-lock && pnpm install",
    "test:unit": "vitest run --dom",
    "catalog": "pnpm dlx codemod pnpm/catalog",
    "catalog:check": "node ./scripts/check-catalog-updates.mjs",
    "catalog:check:all": "node ./scripts/check-catalog-updates.mjs --all",
    "generate-offline-icons": "node scripts/generate-offline-icons.js"
  },
  "dependencies": {
